<UserControl 
	x:Class="Lyt.PhotoPostPro.Panes.CurvePane.GammaCurveView"
	xmlns:vm="clr-namespace:Lyt.PhotoPostPro.Panes.CurvePane"
	x:DataType="vm:GammaCurveViewModel" 

	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"

	xmlns:glyphs="clr-namespace:Lyt.Avalonia.Controls.Glyphs;assembly=Lyt.Avalonia.Controls"
	xmlns:controls="clr-namespace:Lyt.PhotoPostPro.Controls"
	>
	<StackPanel
		Orientation="Vertical"
		> 
		<controls:GammaCurveImageControl
			x:Name="GammaCurveImageControl"
			Margin="2 4 2 4"
			/>
	</StackPanel>
</UserControl>
