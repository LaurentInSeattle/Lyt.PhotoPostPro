<UserControl 
	x:Class="Lyt.PhotoPostPro.Workflow.Shared.DropView"
	xmlns:vm="clr-namespace:Lyt.PhotoPostPro.Workflow.Shared"
	x:DataType="vm:DropViewModel" 

	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"

	IsVisible="{Binding IsVisible}"
	>
	<Grid
		Background="Transparent"
		>
		<Border
			x:Name="DropBorder"
			Margin="8"
			Background="#20808080"
			Width="360" Height="260"
			BorderThickness="0"
			VerticalAlignment="Center" HorizontalAlignment="Left"
			DragDrop.AllowDrop="True"
			>
			<Grid>
				<Rectangle 				
					x:Name="DropRectangle"
					StrokeDashArray="5, 2" 
					Stroke="{StaticResource LightAqua_1_100}" 
					StrokeThickness="4" 
					RadiusX="8" RadiusY="8"  
					Fill="#20808080"
					/>
				<TextBlock
					Margin="0 10 0 0"
					Text="{DynamicResource Folder.DropZone}"
					Theme="{StaticResource H2}"
					TextAlignment="Center"
					HorizontalAlignment="Center" VerticalAlignment="Top"
					/>
				<TextBlock
					Margin="16 0 16 16"
					Text="{DynamicResource Folder.DropZoneHelp}"
					Theme="{StaticResource Medium}"
					TextAlignment="Center"
					HorizontalAlignment="Center" VerticalAlignment="Bottom"
					/>
			</Grid>
		</Border>
	</Grid>
</UserControl>
