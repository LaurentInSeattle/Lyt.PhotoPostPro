<UserControl 
	x:Class="Lyt.PhotoPostPro.Workflow.Process.Exposure.ExposureView"
	xmlns:vm="clr-namespace:Lyt.PhotoPostPro.Workflow.Process.Exposure"
	x:DataType="vm:ExposureViewModel" 
	
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"

	Background="Transparent"
	>
	<Grid> 
		<Grid		
			x:Name="BeforeAfterPortrait"
			IsVisible="{Binding IsPortrait}"
			> 
			<Grid.RowDefinitions>
				<RowDefinition Height="4" />
				<RowDefinition Height="*" />
				<RowDefinition Height="4" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="4" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="8" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="4" />
			</Grid.ColumnDefinitions>
			<Image
				Grid.Column="1" Grid.Row="1"
				IsVisible="{ReflectionBinding SourceImageIsVisible}"
				Source="{ReflectionBinding SourceImage}"
				/>
			<GridSplitter
				x:Name="VerticalSplitter"
				Classes="wide"
				Grid.Row="1" Grid.Column="2" Grid.RowSpan="3" 
				Width="1"
				ResizeDirection="Columns"
				ResizeBehavior="PreviousAndNext"
				DragIncrement="1"
				ShowsPreview="False"
				Background="{StaticResource LightAqua_0_100}"
				Opacity="0.4"
				ZIndex="999"
				/>
			<Image
				Grid.Column="3" Grid.Row="1"
				IsVisible="{ReflectionBinding ResultImageIsVisible}"
				Source="{ReflectionBinding ResultImage}"
				/>
		</Grid>
		<Grid		
			x:Name="BeforeAfterLandscape"
			IsVisible="{Binding !IsPortrait}"
			> 
			<Grid.RowDefinitions>
				<RowDefinition Height="4" />
				<RowDefinition Height="*" />
				<RowDefinition Height="8" />
				<RowDefinition Height="*" />
				<RowDefinition Height="4" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="4" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="4" />
			</Grid.ColumnDefinitions>
			<Image
				Grid.Column="1" Grid.Row="1"
				IsVisible="{ReflectionBinding SourceImageIsVisible}"
				Source="{ReflectionBinding SourceImage}"
				/>
			<GridSplitter
				x:Name="HorizontalSplitter"
				Classes="thick"
				Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5" 
				Height="1"
				ResizeDirection="Rows"
				ResizeBehavior="PreviousAndNext"
				DragIncrement="1"
				ShowsPreview="False"
				Background="{StaticResource LightAqua_0_100}"
				Opacity="0.4"
				ZIndex="999"
				/>
			<Image
				Grid.Column="1" Grid.Row="3"
				IsVisible="{ReflectionBinding ResultImageIsVisible}"
				Source="{ReflectionBinding ResultImage}"
				/>
		</Grid>
	</Grid>
</UserControl>
