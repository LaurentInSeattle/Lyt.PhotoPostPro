<UserControl 
	x:Class="Lyt.PhotoPostPro.Workflow.Process.Export.ExportView"
	xmlns:vm="clr-namespace:Lyt.PhotoPostPro.Workflow.Process.Export"
	x:DataType="vm:ExportViewModel" 
	
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"

	xmlns:shared="clr-namespace:Lyt.PhotoPostPro.Workflow.Process.Shared"
	Background="Transparent"
	>
	<Grid > 
		<Grid.RowDefinitions>
			<RowDefinition Height="4" />
			<RowDefinition Height="*" />
			<RowDefinition Height="4" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="4" />
			<ColumnDefinition Width="*" MinWidth="150"/>
			<ColumnDefinition Width="8" />
			<ColumnDefinition Width="600" MinWidth="150"/>
			<ColumnDefinition Width="4" />
		</Grid.ColumnDefinitions>
		<shared:BeforeAfterView
			Grid.Column="1" Grid.Row="1"
			DataContext="{Binding}"
			/>
		<GridSplitter
			x:Name="VerticalSplitter"
			Classes="wide"
			Grid.Row="1" Grid.Column="2" Grid.RowSpan="3" 
			Width="1"
			ResizeDirection="Columns"
			ResizeBehavior="PreviousAndNext"
			DragIncrement="1"
			ShowsPreview="False"
			Background="{StaticResource LightAqua_0_100}"
			Opacity="0.4"
			ZIndex="999"
			/>
		<Rectangle
			Grid.Column="3" Grid.Row="1"
			Fill="MidnightBlue"
			Opacity="0.3"
			/>
	</Grid>
</UserControl>
