<UserControl 
	x:Class="Lyt.PhotoPostPro.Workflow.Process.Export.ExportToolboxView"
	xmlns:vm="clr-namespace:Lyt.PhotoPostPro.Workflow.Process.Export"
	x:DataType="vm:ExportToolboxViewModel" 

	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="72"

	xmlns:glyphs="clr-namespace:Lyt.Avalonia.Controls.Glyphs;assembly=Lyt.Avalonia.Controls"
	>	
	<Grid
		>
		<Grid.RowDefinitions>
			<RowDefinition Height="{StaticResource Size.PromptThreeLines}" /> <!-- Prompt --> 
			<RowDefinition Height="{StaticResource Size.Spacer}" /> <!-- Spacer --> 
			<RowDefinition Height="{StaticResource Size.WideButtons}" /> <!-- Export Button --> 
			<RowDefinition Height="{StaticResource Size.Spacer}" /> <!-- Spacer --> 
			<RowDefinition Height="{StaticResource Size.Spacer}" /> <!-- Spacer --> 
			<RowDefinition Height="{StaticResource Size.WideButtons}" /> <!-- Navigate Button --> 
			<RowDefinition Height="{StaticResource Size.Spacer}" /> <!-- Spacer --> 
			<RowDefinition Height="{StaticResource Size.Spacer}" /> <!-- Spacer --> 
			<RowDefinition Height="{StaticResource Size.WideButtons}" /> <!-- Finish Button --> 
			<RowDefinition Height="{StaticResource Size.Spacer}" /> <!-- Spacer --> 
			<RowDefinition Height="{StaticResource Size.Spacer}" /> <!-- Spacer --> 
		</Grid.RowDefinitions>
		<TextBlock
			Grid.Row="0" 
			Text="{DynamicResource Workflow.Export.Correction}"
			Theme="{StaticResource Large}"
			TextAlignment="Left" HorizontalAlignment="Left" VerticalAlignment="Center"
			/>
		<glyphs:GlyphButton
			Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
			Style="{StaticResource ControlIconButton}"
			Layout="IconTextLeftSide"
			GlyphSource="arrow_export"
			Text="{DynamicResource Workflow.Export.Export}"
			Command="{Binding OnExport}"
			Width="380" Height="44"
			HorizontalAlignment="Center" VerticalAlignment="Stretch"
	    	/>
		<glyphs:GlyphButton
			Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3"
			Style="{StaticResource ControlIconButton}"
			Layout="IconTextLeftSide"
			GlyphSource="arrow_export_up"
			Text="{DynamicResource Workflow.Export.Navigate}"
			Command="{Binding OnNavigate}"
			Width="380" Height="44"
			HorizontalAlignment="Center" VerticalAlignment="Stretch"
	    	/>
		<glyphs:GlyphButton
			Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3"
			Style="{StaticResource ControlIconButton}"
			Layout="IconTextLeftSide"
			GlyphSource="dismiss"
			Text="{DynamicResource Workflow.Export.Finish}"
			Command="{Binding OnFinish}"
			Width="380" Height="44"
			HorizontalAlignment="Center" VerticalAlignment="Stretch"
	    	/>
	</Grid>	
</UserControl>
