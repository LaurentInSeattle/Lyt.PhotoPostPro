<UserControl 
	x:Class="Lyt.PhotoPostPro.Workflow.Process.Straighten.StraightenToolboxView"
	xmlns:vm="clr-namespace:Lyt.PhotoPostPro.Workflow.Process.Straighten"
	x:DataType="vm:StraightenToolboxViewModel" 

	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="72"

	xmlns:glyphs="clr-namespace:Lyt.Avalonia.Controls.Glyphs;assembly=Lyt.Avalonia.Controls"
	xmlns:controls="using:Lyt.PhotoPostPro.Controls"
	>	
	<Grid
		Margin="4 0 0 0"
		> 
		<Grid.RowDefinitions>
			<RowDefinition Height="{StaticResource Size.Title}" /> <!-- Title --> 
			<RowDefinition Height="{StaticResource Size.PromptOneLine}" /> <!-- Prompt Guidelines --> 
			<RowDefinition Height="{StaticResource Size.PanelButtons}" /> <!-- Guidelines Buttons --> 
			<RowDefinition Height="{StaticResource Size.PanelButtons}" /> <!-- Guidelines Colours Buttons --> 
			<RowDefinition Height="{StaticResource Size.Spacer}" /> <!-- Spacer --> 
			<RowDefinition Height="{StaticResource Size.PromptOneLine}" /> <!-- Prompt Rotates --> 
			<RowDefinition Height="{StaticResource Size.PanelButtons}" /> <!-- Rotate Buttons +/ -1   --> 
			<RowDefinition Height="{StaticResource Size.PanelButtons}" /> <!-- Rotate Buttons +/ -0.5 --> 
			<RowDefinition Height="{StaticResource Size.Spacer}" /> <!-- Spacer --> 
			<RowDefinition Height="{StaticResource Size.WfNav}" /> <!-- Workflow Button Grid  --> 
			<RowDefinition Height="{StaticResource Size.Separator}" /> <!-- Separator --> 
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions> 
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<TextBlock
			Grid.Row="0" Grid.ColumnSpan="3"
			Text="{DynamicResource Workflow.Straighten.Title}"
			Theme="{StaticResource H2}"
			TextAlignment="Left" HorizontalAlignment="Left" VerticalAlignment="Center"
			/>
		<TextBlock
			Grid.Row="1" Grid.ColumnSpan="3"
			Text="{DynamicResource Workflow.Straighten.Guidelines}"
			Theme="{StaticResource Large}"
			TextAlignment="Left" HorizontalAlignment="Left" VerticalAlignment="Center"
			/>
		<glyphs:GlyphButton
			Grid.Row="2" Grid.Column="0"
			Style="{StaticResource PanelIconButton}"
			Margin="4"
			Text="{DynamicResource Workflow.Straighten.VerticalGuideline}"
			GlyphSource="line"
			GlyphAngle="-45"
			Command="{Binding OnToggleVerticalGuideline}"
			GlyphStrokeThickness="0.05" 
			/>		
		<glyphs:GlyphButton
			Grid.Row="2" Grid.Column="2"
			Style="{StaticResource PanelIconButton}"
			Text="{DynamicResource Workflow.Straighten.HorizontalGuideline}"
			GlyphSource="line"
			GlyphAngle="45"
			Command="{Binding OnToggleHorizontalGuideline}"
			Margin="4"
			GlyphStrokeThickness="0.05" 
			/>
		<!-- Colour Buttons --> 
		<Grid
			Grid.Row="3" Grid.ColumnSpan="3"
			Margin="0 0 0 0"
			HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
			>
			<Grid.ColumnDefinitions> 
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<glyphs:SelectionGroup x:Name="ColorsSelectionGroup" />

			<glyphs:GlyphButton
				Grid.Column="0"
				Style="{StaticResource ColorIconButton}"
				Group="{Binding ElementName=ColorsSelectionGroup}"
				Command="{Binding OnColorSelect}"
				CommandParameter="0"
				>
				<glyphs:GlyphButton.XamlContent>
					<controls:ColoredControl
						BorderBrush="{Binding Color_0}"
						/>
				</glyphs:GlyphButton.XamlContent>
			</glyphs:GlyphButton>
			<glyphs:GlyphButton
				Grid.Column="1"
				Style="{StaticResource ColorIconButton}"
				Group="{Binding ElementName=ColorsSelectionGroup}"
				Command="{Binding OnColorSelect}"
				CommandParameter="1"
				>
				<glyphs:GlyphButton.XamlContent>
					<controls:ColoredControl
						BorderBrush="{Binding Color_1}"
						/>
				</glyphs:GlyphButton.XamlContent>
			</glyphs:GlyphButton>

			<glyphs:GlyphButton
				Grid.Column="2"
				Style="{StaticResource ColorIconButton}"
				Group="{Binding ElementName=ColorsSelectionGroup}"
				Command="{Binding OnColorSelect}"
				CommandParameter="2"
				>
				<glyphs:GlyphButton.XamlContent>
					<controls:ColoredControl
						BorderBrush="{Binding Color_2}"
						/>
				</glyphs:GlyphButton.XamlContent>
			</glyphs:GlyphButton>
			<glyphs:GlyphButton
				Grid.Column="3"
				Style="{StaticResource ColorIconButton}"
				Group="{Binding ElementName=ColorsSelectionGroup}"
				IsSelected="True"
				Command="{Binding OnColorSelect}"
				CommandParameter="3"
				>
				<glyphs:GlyphButton.XamlContent>
					<controls:ColoredControl
						BorderBrush="{Binding Color_3}"
						/>
				</glyphs:GlyphButton.XamlContent>
			</glyphs:GlyphButton>

			<glyphs:GlyphButton
				Grid.Column="4"
				Style="{StaticResource ColorIconButton}"
				Group="{Binding ElementName=ColorsSelectionGroup}"
				Command="{Binding OnColorSelect}"
				CommandParameter="4"
				>
				<glyphs:GlyphButton.XamlContent>
					<controls:ColoredControl
						BorderBrush="{Binding Color_4}"
						/>
				</glyphs:GlyphButton.XamlContent>
			</glyphs:GlyphButton>
		</Grid>

		<!-- Rotates Buttons--> 
		<TextBlock
			Grid.Row="5" Grid.ColumnSpan="3"
			Text="{DynamicResource Workflow.Straighten.Rotate}"
			Theme="{StaticResource Large}"
			TextAlignment="Left" HorizontalAlignment="Left" VerticalAlignment="Center"
			/>
		<glyphs:GlyphButton
			Grid.Row="6" Grid.Column="0"
			Style="{StaticResource PanelIconButton}"
			Margin="4"
			Text="{DynamicResource Workflow.Straighten.RotateMinusLarge}"
			GlyphSource="arrow_rotate_counterclockwise"
			Command="{Binding OnRotateCounterClockwiseLarge}"
			GlyphStrokeThickness="0.05" 
			/>

		<glyphs:GlyphButton
			Grid.Row="6" Grid.Column="1"
			Style="{StaticResource PanelIconButton}"
			Text="{DynamicResource Workflow.Straighten.ClearRotate}"
			GlyphSource="dismiss"
			Command="{Binding OnClearRotate}"
			Margin="4"
			GlyphStrokeThickness="0.05" 
			/>
		<glyphs:GlyphButton
			Grid.Row="6" Grid.Column="2"
			Style="{StaticResource PanelIconButton}"
			Text="{DynamicResource Workflow.Straighten.RotatePlusLarge}"
			GlyphSource="arrow_rotate_clockwise"
			Command="{Binding OnRotateClockwiseLarge}"
			Margin="4"
			GlyphStrokeThickness="0.05" 
			/>

		<glyphs:GlyphButton
			Grid.Row="7" Grid.Column="0"
			Style="{StaticResource PanelIconButton}"
			Margin="4"
			Text="{DynamicResource Workflow.Straighten.RotateMinusSmall}"
			GlyphSource="arrow_rotate_counterclockwise"
			Command="{Binding OnRotateCounterClockwiseSmall}"
			GlyphStrokeThickness="0.05" 
			/>
		<glyphs:GlyphButton
			Grid.Row="7" Grid.Column="2"
			Style="{StaticResource PanelIconButton}"
			Text="{DynamicResource Workflow.Straighten.RotatePlusSmall}"
			GlyphSource="arrow_rotate_clockwise"
			Command="{Binding OnRotateClockwiseSmall}"
			Margin="4"
			GlyphStrokeThickness="0.05" 
			/>

		<!-- Workflow Button Grid --> 
		<Grid
			Grid.Row="9" Grid.ColumnSpan="3"
			Margin="0 0 0 0"
			HorizontalAlignment="Stretch"
			Height="72"
			>
			<Grid.ColumnDefinitions> 
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<glyphs:GlyphButton
				Grid.Column="0"
				Style="{StaticResource ControlIconButton}"
				GlyphSource="next"
				GlyphAngle="180"
				Text="{DynamicResource Workflow.Back}"
				Command="{ReflectionBinding OnBack}"
	    		/>
			<glyphs:GlyphButton
				Grid.Column="1"
				Style="{StaticResource ControlIconButton}"
				Layout="IconTextLeftSide"
				GlyphSource="next"
				Text="{DynamicResource Workflow.Next}"
				Command="{ReflectionBinding OnNext}"
	    		/>
		</Grid>
		<!-- Separator --> 
		<Separator 
			Grid.Column="0" Grid.ColumnSpan="999" Grid.Row="10"
			Height="1"
			VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
			>
			<Separator.Background>
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
					<GradientStop Color="Transparent" Offset="0.0" />
					<GradientStop Color="{StaticResource LightAqua_1_040_Color}" Offset="0.5" />
					<GradientStop Color="Transparent" Offset="1.0" />
				</LinearGradientBrush>
			</Separator.Background>
		</Separator>
	</Grid>
</UserControl>