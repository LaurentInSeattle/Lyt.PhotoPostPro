<UserControl 
	x:Class="Lyt.PhotoPostPro.Workflow.Process.ProcessToolbarView"
	xmlns:vm="clr-namespace:Lyt.PhotoPostPro.Workflow.Process"
	x:DataType="vm:ProcessToolbarViewModel" 

	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="72"

	xmlns:shared="clr-namespace:Lyt.PhotoPostPro.Workflow.Shared"
	xmlns:glyphs="clr-namespace:Lyt.Avalonia.Controls.Glyphs;assembly=Lyt.Avalonia.Controls"
	xmlns:interactions="using:Lyt.Avalonia.Mvvm.Behaviors"
	>	
	<StackPanel
		Orientation="Vertical"
		Margin="0 0 0 0"
		HorizontalAlignment="Left"
		Background="#30000080"
		>
		<!-- TODO 

		<glyphs:GlyphButton
			Style="{StaticResource ToolbarIconButton}"
			Behaviour="Tap"
			HorizontalAlignment="Center" VerticalAlignment="Center"
			Width="220" Height="56"
			Margin="0 4 0 4"
			GlyphSource="next"
			ButtonBackground="BorderlessRectangle"
			GlyphStrokeThickness="0"
			Text="{DynamicResource Language.Continue}"
			Command="{Binding OnNext}"
	    	/>
		-->
	</StackPanel>

</UserControl>