<UserControl 
	x:Class="Lyt.PhotoPostPro.Workflow.Process.Lut.LutToolboxView"
	xmlns:vm="clr-namespace:Lyt.PhotoPostPro.Workflow.Process.Lut"
	x:DataType="vm:LutToolboxViewModel" 

	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="782"

	xmlns:shared="clr-namespace:Lyt.PhotoPostPro.Workflow.Shared"
	>	
	<Grid
		>
		<Grid.RowDefinitions>
			<RowDefinition Height="{StaticResource Size.PromptTwoLines}" /> <!-- Prompt LUT --> 
			<RowDefinition Height="{StaticResource Size.ComboBox}" /> <!--  : LUT combo --> 
			<RowDefinition Height="{StaticResource Size.Spacer}" /> <!--  --> 
			<RowDefinition Height="{StaticResource Size.PromptOneLine}" /> <!-- Prompt Drop LUT --> 
			<RowDefinition Height="{StaticResource Size.DropBox}" /> <!--  : Drop   --> 
			<RowDefinition Height="{StaticResource Size.Spacer}" /> <!--  --> 
		</Grid.RowDefinitions>
		<TextBlock
			Grid.Row="0" 
			Text="{DynamicResource Workflow.Lut.Correction}"
			Theme="{StaticResource Large}"
			TextAlignment="Left" HorizontalAlignment="Left" VerticalAlignment="Center"
			/>
		<Grid
			Grid.Row="1" 
			> 
			<ComboBox
				x:Name="ContentComboBox"
				Margin="12 0 0 0"
				Padding="1"
				VerticalAlignment="Center" HorizontalAlignment="Left"
				ItemsSource="{Binding AvailableLutNames}"
				SelectedIndex="{Binding SelectedIndex}"
				Width="300" Height="44" MaxDropDownHeight="340"
				>
				<ComboBox.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel Orientation="Vertical"/>
					</ItemsPanelTemplate>
				</ComboBox.ItemsPanel>
				<ComboBox.ItemTemplate>
					<DataTemplate>
						<TextBlock 
							Theme="{StaticResource Large}"
							Foreground="{StaticResource Secondary.TextColor}"
							Margin ="16 0 0 0" 
							Text="{Binding}"
							/>
					</DataTemplate>
				</ComboBox.ItemTemplate>
			</ComboBox>		
		</Grid>
		<TextBlock
			Grid.Row="3" 
			Text="{DynamicResource Workflow.Lut.DropLut}"
			Theme="{StaticResource Large}"
			TextAlignment="Left" HorizontalAlignment="Left" VerticalAlignment="Center"
			/>
		<shared:DropView
			Grid.Row="4" 
			Margin="4"
			DataContext="{Binding DropViewModel}"
			/>
	</Grid>
</UserControl>
