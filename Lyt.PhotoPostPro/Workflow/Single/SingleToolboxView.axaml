<UserControl 
	x:Class="Lyt.PhotoPostPro.Workflow.Single.SingleToolboxView"
	xmlns:vm="clr-namespace:Lyt.PhotoPostPro.Workflow.Single"
	x:DataType="vm:SingleToolboxViewModel" 

	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="72"

	xmlns:shared="clr-namespace:Lyt.PhotoPostPro.Workflow.Shared"
	xmlns:glyphs="clr-namespace:Lyt.Avalonia.Controls.Glyphs;assembly=Lyt.Avalonia.Controls"
	xmlns:interactions="using:Lyt.Avalonia.Mvvm.Behaviors"
	>	
	<StackPanel
		Orientation="Vertical"
		Margin="0 0 0 0"
		HorizontalAlignment="Left"
		Background="#30000080"
		>
		<shared:DropView
			Margin="4"
			DataContext="{Binding DropViewModel}"
			/>
		<glyphs:GlyphButton
			Style="{StaticResource ViewIconButton}"
			FontSize="24"
			HorizontalAlignment="Center" VerticalAlignment="Center"
			Width="360" Height="56"
			Margin="0 12 0 12"
			GlyphSource="wand"
			ButtonBackground="BorderlessRectangle"
			GlyphStrokeThickness="0"
			Text="{DynamicResource Single.ProcessImage}"
			Command="{Binding OnNext}"
	    	/>
		<TextBlock
			Theme="{StaticResource Medium}"
			TextAlignment="Center"
			HorizontalAlignment="Center" VerticalAlignment="Bottom" 
			Text="TODO: File Name"
			/>
	</StackPanel>

</UserControl>