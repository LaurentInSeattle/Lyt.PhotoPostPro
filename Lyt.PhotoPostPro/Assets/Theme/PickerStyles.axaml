<Styles 
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Style Selector="DatePickerPresenter">
		<Setter Property="Foreground" Value="{StaticResource LightAqua_0_120}" />
		<Setter Property="Background" Value="{StaticResource DeepBlue_0_100}" />
	</Style>

	<Style Selector="DatePicker /template/ TextBlock#PART_DayTextBlock">
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="Foreground" Value="{StaticResource LightAqua_0_100}" />
	</Style>

	<Style Selector="DatePicker /template/ TextBlock#PART_MonthTextBlock">
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="Foreground" Value="{StaticResource LightAqua_0_100}" />
	</Style>

	<Style Selector="DatePicker /template/ TextBlock#PART_YearTextBlock">
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="Foreground" Value="{StaticResource LightAqua_0_100}" />
	</Style>

	<Style Selector="TimePickerPresenter">
		<Setter Property="Foreground" Value="{StaticResource LightAqua_0_120}" />
		<Setter Property="Background" Value="{StaticResource DeepBlue_0_100}" />
	</Style>

	<Style Selector="TimePicker /template/ TextBlock#PART_HourTextBlock">
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="Foreground" Value="{StaticResource LightAqua_0_100}" />
	</Style>

	<Style Selector="TimePicker /template/ TextBlock#PART_MinuteTextBlock">
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="Foreground" Value="{StaticResource LightAqua_0_100}" />
	</Style>

</Styles>
